#!/bin/sh
# ==============================================================
# Commit-msg Hook for RocoTools
# Location: scripts/git-hooks/commit-msg
# Validates commit message format
# ==============================================================

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits
if echo "$COMMIT_MSG" | grep -qE '^Merge'; then
  exit 0
fi

# Valid prefixes
VALID_PREFIXES="feat|fix|docs|style|refactor|perf|chore|release|build|ci|test|hotfix"

# Check format: prefix: message (or prefix(scope): message)
if ! echo "$COMMIT_MSG" | grep -qE "^($VALID_PREFIXES)(\(.+\))?: .+"; then
  echo ""
  echo "${RED}❌ Invalid commit message format!${NC}"
  echo ""
  echo "  Your message: \"$COMMIT_MSG\""
  echo ""
  echo "  Expected format: ${GREEN}<type>: <description>${NC}"
  echo "  Or with scope:   ${GREEN}<type>(<scope>): <description>${NC}"
  echo ""
  echo "  Valid types:"
  echo "    feat:     New feature"
  echo "    fix:      Bug fix"
  echo "    docs:     Documentation changes"
  echo "    style:    Code style (formatting, no logic change)"
  echo "    refactor: Code refactoring"
  echo "    perf:     Performance improvement"
  echo "    chore:    Build/tooling/misc changes"
  echo "    release:  Version release"
  echo "    build:    Build system changes"
  echo "    ci:       CI/CD changes"
  echo "    test:     Test changes"
  echo "    hotfix:   Emergency fix"
  echo ""
  echo "  Examples:"
  echo "    feat: add pet comparison feature"
  echo "    fix(admin): resolve skill editor crash"
  echo "    release: V1.1"
  echo ""
  echo "  To bypass: git commit --no-verify"
  echo ""
  exit 1
fi

# Check minimum length (at least 10 chars total)
MSG_LENGTH=$(echo "$COMMIT_MSG" | wc -c | tr -d ' ')
if [ "$MSG_LENGTH" -lt 10 ]; then
  echo "${YELLOW}⚠️  Commit message is too short. Please be more descriptive.${NC}"
  exit 1
fi

echo "${GREEN}✅ Commit message format OK${NC}"
exit 0
