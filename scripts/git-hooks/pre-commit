#!/bin/sh
# ==============================================================
# Pre-commit Hook for RocoTools
# Location: scripts/git-hooks/pre-commit
# Activate: git config core.hooksPath scripts/git-hooks
# ==============================================================

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

echo "${CYAN}🔍 Running pre-commit checks...${NC}"
echo ""

ERRORS=0
WARNINGS=0

# Get list of staged files (excluding deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$STAGED_FILES" ]; then
  echo "${GREEN}✅ No staged files, skipping checks.${NC}"
  exit 0
fi

# ==============================================================
# CHECK 1: Detect console.log in staged JS/Vue/TS files
# ==============================================================
echo "${CYAN}[1/7] Checking for console.log...${NC}"

JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|vue|ts|jsx|tsx)$' || true)

if [ -n "$JS_FILES" ]; then
  # Check staged content (not working tree) for console.log
  CONSOLE_LOG_FILES=""
  for file in $JS_FILES; do
    if git diff --cached -- "$file" | grep -q '^\+.*console\.log'; then
      CONSOLE_LOG_FILES="$CONSOLE_LOG_FILES\n  - $file"
    fi
  done

  if [ -n "$CONSOLE_LOG_FILES" ]; then
    echo "${YELLOW}  ⚠️  Found console.log in staged changes:${CONSOLE_LOG_FILES}${NC}"
    WARNINGS=$((WARNINGS + 1))
  else
    echo "  ✓ No console.log found"
  fi
else
  echo "  ✓ No JS/Vue files staged"
fi

# ==============================================================
# CHECK 2: Detect debugger statements
# ==============================================================
echo "${CYAN}[2/7] Checking for debugger statements...${NC}"

if [ -n "$JS_FILES" ]; then
  DEBUGGER_FILES=""
  for file in $JS_FILES; do
    if git diff --cached -- "$file" | grep -q '^\+.*debugger'; then
      DEBUGGER_FILES="$DEBUGGER_FILES\n  - $file"
    fi
  done

  if [ -n "$DEBUGGER_FILES" ]; then
    echo "${RED}  ❌ Found debugger statements in:${DEBUGGER_FILES}${NC}"
    ERRORS=$((ERRORS + 1))
  else
    echo "  ✓ No debugger statements found"
  fi
else
  echo "  ✓ No JS/Vue files staged"
fi

# ==============================================================
# CHECK 3: Prevent .env files from being committed
# ==============================================================
echo "${CYAN}[3/7] Checking for .env files...${NC}"

ENV_FILES=$(echo "$STAGED_FILES" | grep -E '(^|/)\.env$' || true)

if [ -n "$ENV_FILES" ]; then
  echo "${RED}  ❌ .env file(s) staged for commit:${NC}"
  echo "$ENV_FILES" | while read -r f; do echo "    - $f"; done
  echo "${RED}  These files contain sensitive data and must not be committed!${NC}"
  ERRORS=$((ERRORS + 1))
else
  echo "  ✓ No .env files staged"
fi

# ==============================================================
# CHECK 4: Prevent .db files from being committed
# ==============================================================
echo "${CYAN}[4/7] Checking for database files...${NC}"

DB_FILES=$(echo "$STAGED_FILES" | grep -E '\.(db|db-shm|db-wal)$' || true)

if [ -n "$DB_FILES" ]; then
  echo "${RED}  ❌ Database file(s) staged for commit:${NC}"
  echo "$DB_FILES" | while read -r f; do echo "    - $f"; done
  echo "${RED}  Database files should not be in version control!${NC}"
  ERRORS=$((ERRORS + 1))
else
  echo "  ✓ No database files staged"
fi

# ==============================================================
# CHECK 5: Prevent large files (>5MB) from being committed
# ==============================================================
echo "${CYAN}[5/7] Checking for large files (>5MB)...${NC}"

LARGE_FILES=""
for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    FILE_SIZE=$(wc -c < "$file" 2>/dev/null | tr -d ' ')
    if [ -n "$FILE_SIZE" ] && [ "$FILE_SIZE" -gt 5242880 ]; then
      SIZE_MB=$(echo "scale=1; $FILE_SIZE / 1048576" | bc 2>/dev/null || echo "${FILE_SIZE}B")
      LARGE_FILES="$LARGE_FILES\n  - $file (${SIZE_MB}MB)"
    fi
  fi
done

if [ -n "$LARGE_FILES" ]; then
  echo "${RED}  ❌ Large files detected (>5MB):${LARGE_FILES}${NC}"
  ERRORS=$((ERRORS + 1))
else
  echo "  ✓ No large files detected"
fi

# ==============================================================
# CHECK 6: Auto-fix trailing whitespace in staged files
# ==============================================================
echo "${CYAN}[6/7] Fixing trailing whitespace...${NC}"

FIXABLE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|vue|ts|jsx|tsx|css|scss|html|json|md)$' || true)
FIXED_COUNT=0

if [ -n "$FIXABLE_FILES" ]; then
  for file in $FIXABLE_FILES; do
    if [ -f "$file" ]; then
      # Check if file has trailing whitespace
      if grep -qP '[ \t]+$' "$file" 2>/dev/null; then
        # Remove trailing whitespace
        sed -i 's/[[:space:]]*$//' "$file"
        git add "$file"
        FIXED_COUNT=$((FIXED_COUNT + 1))
      fi
    fi
  done

  if [ "$FIXED_COUNT" -gt 0 ]; then
    echo "  ✓ Fixed trailing whitespace in $FIXED_COUNT file(s)"
  else
    echo "  ✓ No trailing whitespace found"
  fi
else
  echo "  ✓ No fixable files staged"
fi

# ==============================================================
# CHECK 7: Build check (only when client files are modified)
# ==============================================================
echo "${CYAN}[7/7] Checking if frontend build is needed...${NC}"

CLIENT_FILES=$(echo "$STAGED_FILES" | grep -E '^app/client/' || true)

if [ -n "$CLIENT_FILES" ]; then
  echo "  Frontend files changed, running build check..."

  # Save current directory
  ORIGINAL_DIR=$(pwd)

  # Try to build
  cd app/client 2>/dev/null
  if [ $? -eq 0 ]; then
    BUILD_OUTPUT=$(npm run build 2>&1)
    BUILD_EXIT=$?
    cd "$ORIGINAL_DIR"

    if [ $BUILD_EXIT -ne 0 ]; then
      echo "${RED}  ❌ Frontend build failed!${NC}"
      echo "${RED}  Please fix build errors before committing.${NC}"
      echo ""
      echo "$BUILD_OUTPUT" | tail -20
      ERRORS=$((ERRORS + 1))
    else
      echo "  ✓ Frontend build successful"
      # Stage the build output if it changed
      git add app/server/public/ 2>/dev/null || true
    fi
  else
    cd "$ORIGINAL_DIR"
    echo "${YELLOW}  ⚠️  Cannot access app/client directory, skipping build check${NC}"
  fi
else
  echo "  ✓ No frontend files changed, skipping build"
fi

# ==============================================================
# SUMMARY
# ==============================================================
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $ERRORS -gt 0 ]; then
  echo "${RED}❌ Pre-commit failed with $ERRORS error(s) and $WARNINGS warning(s)${NC}"
  echo "${RED}   Commit aborted. Please fix the errors above.${NC}"
  echo ""
  echo "   To bypass (not recommended): git commit --no-verify"
  exit 1
elif [ $WARNINGS -gt 0 ]; then
  echo "${YELLOW}⚠️  Pre-commit passed with $WARNINGS warning(s)${NC}"
  echo "${GREEN}   Commit will proceed. Consider fixing warnings later.${NC}"
  exit 0
else
  echo "${GREEN}✅ All pre-commit checks passed!${NC}"
  exit 0
fi
